# ==========================================
# SocietyKro — Environment Variables
# Copy to .env and fill in values
# ==========================================

# --- Application ---
APP_NAME=societykro
APP_ENV=development
APP_PORT=8080
APP_DEBUG=true

# --- Database (PostgreSQL) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=societykro
DATABASE_USER=societykro
DATABASE_PASSWORD=societykro_dev
DATABASE_SSL_MODE=disable
DATABASE_MAX_CONNECTIONS=25
DATABASE_URL=postgres://societykro:societykro_dev@localhost:5432/societykro?sslmode=disable

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# --- NATS ---
NATS_URL=nats://localhost:4222

# --- MinIO (S3 compatible for local dev) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=societykro-dev
S3_REGION=us-east-1
S3_USE_SSL=false

# --- JWT ---
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=720h

# --- OTP ---
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_WINDOW=900

# --- SMS (MSG91) ---
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=SCTKRO

# --- WhatsApp (Meta Cloud API) ---
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_VERIFY_TOKEN=societykro_webhook_verify
META_WA_APP_SECRET=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Bhashini (Voice/Translation) ---
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_PIPELINE_URL=https://dhruva-api.bhashini.gov.in/services/inference/pipeline

# --- Firebase (Push Notifications) ---
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./keys/firebase-service-account.json

# --- Sentry (Error Tracking) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- PostHog (Analytics) ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# --- Service Ports (local dev) ---
AUTH_SERVICE_PORT=8081
COMPLAINT_SERVICE_PORT=8082
VISITOR_SERVICE_PORT=8083
PAYMENT_SERVICE_PORT=8084
NOTICE_SERVICE_PORT=8085
VENDOR_SERVICE_PORT=8086
CHATBOT_SERVICE_PORT=8087
NOTIFICATION_SERVICE_PORT=8088
MESSAGE_ROUTER_PORT=8089
VOICE_SERVICE_PORT=8090
WEB_ADMIN_PORT=3000
